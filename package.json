{
  "name": "loose-cannon",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c yellow,cyan \"npm run server\" \"npm run client\"",
    "server": "npm run start -w @loose-cannon/server",
    "client": "npm run dev -w @loose-cannon/client",
    "smoke": "node packages/server/scripts/smoke.mjs",
    "voice:gen": "node scripts/voice/generate-voice.mjs",
    "build": "npm run build -w @loose-cannon/shared && npm run build -w @loose-cannon/server && npm run build -w @loose-cannon/client",
    "build:azure": "node scripts/prepare-azure-deploy.mjs",
    "build:azure:client": "node scripts/prepare-azure-deploy.mjs",
    "start:client:prod": "node packages/client/static-server.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.12",
    "typescript": "^5.8.2"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.25.12": true
  }
}
